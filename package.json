{
  "name": "habit-flow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "pnpm build && vite preview",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --reporter verbose",
    "test:unit:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "slice": "create-slice.bat",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {    
    "*.(ts|tsx)": ["npm check:write", "git add"]  
  },
  "dependencies": {
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "@vue/tsconfig": "^0.8.1",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.1.5"
  }
}
